# ============================================================
# 后端配置 —— 启动时 godotenv 自动从 backend/.env 加载
# 用法：cp backend/.env.example backend/.env，然后填值
# 生产环境用云平台 secret 注入 process env，不需要 .env 文件
# ============================================================

# 后端 HTTP 端口
PORT=8080

# GitHub API token（PAT）。可选但推荐 —— 不配会撞匿名速率限制（60 req/h），且无法读私有仓
GITHUB_TOKEN=

# LLM 选型：
#   mock   —— 写死回复，不发网络请求，本地开发 / 演示用
#   openai —— 任意 OpenAI 兼容 endpoint（DeepSeek / OpenAI / Kimi …）
LLM_PROVIDER=mock

# OpenAI 兼容 endpoint 配置（LLM_PROVIDER=openai 时生效）
# 默认指 DeepSeek；改 OPENAI_BASE_URL 即可切到 OpenAI / Kimi / 通义 等
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# SQLite 数据库路径。父目录不存在时自动创建
SQLITE_PATH=./data/reviews.db

# ============================================================
# v3 真部署相关（v1/v2 留空即可，回退到 SQLite + 内存）
# ============================================================

# Postgres：非空时切到 PostgresStore；形如 postgres://user:pass@host:5432/dbname?sslmode=disable
POSTGRES_URL=

# Redis：非空时切到 RedisCache（rate limit 计数 / SSE session 共享 / RAG 队列）；形如 redis://:password@host:6379/0
REDIS_URL=

# GitHub App（v3 OAuth + Webhook）。完整套需要五项齐备：
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 可观测性（v3）
SENTRY_DSN=
OTLP_ENDPOINT=
ENVIRONMENT=development
